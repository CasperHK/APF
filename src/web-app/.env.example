# Runtime port (Elysia + SolidStart share the same process)
PORT=3000

# External AI / Redis / Vector DB (used by agent-worker container)
REDIS_URL=redis://redis:6379
VECTOR_DB_URL=postgresql://pguser:pgpassword@vector-db:5432/vectordb

# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_key
DEEPSEEK_API_KEY=your_deepseek_key
