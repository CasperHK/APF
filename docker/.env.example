# Docker Compose env vars for production
# Copy to .env.prod and fill in real values — DO NOT commit real keys!

# LLM API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# Database passwords (override defaults)
POSTGRES_PASSWORD=change_me_in_production

# Optional: external Redis URL (leave empty to use the bundled service)
# REDIS_URL=redis://your-external-redis:6379
