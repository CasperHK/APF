# ── Agent Worker Dockerfile ───────────────────────────────────────────────
# Python / CrewAI / LangGraph container for AI task execution.
# Communicates with the APF API server via Redis Pub/Sub.
# ─────────────────────────────────────────────────────────────────────────

FROM python:3.12-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
COPY src/agent-worker/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Application source
COPY src/agent-worker/ ./

# Create secure workspace mount point
RUN mkdir -p /secure_workspace && chmod 750 /secure_workspace

ENV PYTHONUNBUFFERED=1

CMD ["python", "main.py"]
